{
  "name": "HMall-ai-service",
  "version": "1.0.0",
  "description": "HMall AI Recommendation Service with ML Models",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "train": "ts-node src/ml/train-simple.ts",
    "train:content": "ts-node src/ml/train-simple.ts --model=content",
    "train:collaborative": "ts-node src/ml/train-simple.ts --model=collaborative",
    "train:hybrid": "ts-node src/ml/train-simple.ts --model=hybrid"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ml-matrix": "^6.10.4",
    "natural": "^6.10.2",
    "node-cron": "^4.2.1",
    "simple-statistics": "^7.8.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/natural": "^5.1.3",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
